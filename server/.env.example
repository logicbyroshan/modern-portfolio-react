# Django (local development)
DJANGO_SECRET_KEY=django-insecure-local-development-key-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,testserver

# Keep empty unless clients send X-API-Key explicitly.
PORTFOLIO_API_KEY=
TINYMCE_API_KEY=no-api-key

# Security (local)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin
SECURE_CROSS_ORIGIN_RESOURCE_POLICY=same-origin
X_FRAME_OPTIONS=DENY
USE_X_FORWARDED_HOST=False
TRUST_X_FORWARDED_PROTO=False
TRUST_X_FORWARDED_FOR=False
DISALLOW_SQLITE_IN_PRODUCTION=True

# Domains (optional in local)
PUBLIC_SITE_DOMAIN=
ADMIN_SITE_DOMAIN=

# Database (local sqlite by default)
# Leave DB_ENGINE unset for sqlite.
DB_CONN_MAX_AGE=0
DB_CONN_HEALTH_CHECKS=False
DB_CONNECT_TIMEOUT=10
DB_STATEMENT_TIMEOUT_MS=15000
DB_OPTIONS=

# CORS / CSRF (local)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=False
CORS_ALLOWED_METHODS=GET,POST,OPTIONS
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
