# Local/default frontend configuration
# Use /api for local dev (Vite proxy) and same-origin deployments.
VITE_API_BASE_URL=/api

# API request behavior
VITE_API_TIMEOUT_MS=7000
VITE_API_RETRY_ATTEMPTS=1

# Session cache duration for bootstrap payload (milliseconds)
VITE_PORTFOLIO_CACHE_TTL_MS=300000
